# Integration tests for the jq extension.
# Run via: make test
#
# Format reference: https://duckdb.org/dev/sqllogictest/intro.html
# - query T = VARCHAR result, query I = INTEGER, query R = REAL, query B = BOOLEAN
# - Expected output must match DuckDB's exact format (see LESSONS.md Pitfall P5)

# Verify the extension loads without error
require jq

# ---- Replace the examples below with your actual function tests ----

# Example: test a scalar function that returns a VARCHAR
# query T
# SELECT jq_hello('world');
# ----
# Hello from jq! world

# Example: test an aggregate function
# query I
# SELECT jq_count(col) FROM (VALUES (1), (2), (3)) t(col);
# ----
# 3

# Example: NULL handling
# query I
# SELECT jq_count(col) FROM (VALUES (NULL), (1)) t(col);
# ----
# 1
